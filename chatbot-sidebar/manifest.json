{
  "manifest_version": 3,
  "name": "Chat Sidebar",
  "version": "1.0",
  "description": "A simple chatbot sidebar like Elmo.chat",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "side_panel": {
    "default_path": "panel.html",
    "openPanelOnActionClick": true
  },
  "action": {
    "default_title": "Click to open Sidebar Clock"
  },
  "offline_enabled": true,
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel"]
}